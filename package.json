{
  "name": "next-starter-template",
  "version": "1.0.0",
  "description": "Official Lou Gehrig Fan Club website.",
  "keywords": [
    "nextjs",
    "typescript",
    "cloudflare-pages",
    "starter-template",
    "react",
    "nextjs-template",
    "fullstack",
    "cloudflare",
    "static-site",
    "nextjs-15",
    "react-19"
  ],
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/wdhunter645/next-starter-template.git"
  },
  "homepage": "https://www.lougehrigfanclub.com",
  "bugs": {
    "url": "https://github.com/wdhunter645/next-starter-template/issues"
  },
  "cloudflare": {
    "label": "Next.js Framework Starter",
    "products": [
      "Pages"
    ],
    "categories": [],
    "preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/05eee9e0-2c04-48fd-11bf-84e65f839000/public",
    "preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/4e913a56-fd99-4372-0586-9f1364173100/preview",
    "publish": true
  },
  "scripts": {
    "dev": "next dev",
    "dev:cf": "wrangler pages dev out --compatibility-date=2025-10-30 --compatibility-flags=nodejs_compat --d1=DB --live-reload",
    "build": "rm -rf out .next && next build && npm run postbuild",
    "postbuild": "cp _routes.json out/_routes.json && node scripts/postbuild-ai-review-routes.mjs",
    "build:cf": "npm run build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:homepage-structure": "vitest run tests/homepage-structure.test.tsx",
    "verify-homepage": "npm run test:homepage-structure",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:homepage-sections": "playwright test tests/e2e/homepage-sections.spec.ts",
    "verify-homepage-e2e": "playwright test tests/e2e/homepage-sections.spec.ts",
    "check": "npm run build && tsc",
    "check:structure": "node scripts/check-repo-structure.mjs",
    "snapshot": "node scripts/make-snapshot.mjs",
    "assess": "node scripts/assess.mjs",
    "assess:ci": "node scripts/assess.mjs --ci",
    "verify:invariants": "node scripts/ci/verify_lgfc_invariants.mjs",
    "launch-readiness:unit": "vitest run tests/launch-readiness-manifest.test.ts tests/d1-b2-fail-closed.test.ts tests/homepage-structure.test.tsx tests/join-login-auth.test.tsx tests/mobile-navigation.test.tsx",
    "launch-readiness:e2e": "LAUNCH_READINESS_E2E=1 playwright test tests/e2e/launch-readiness-public-routes.spec.ts tests/e2e/launch-readiness-fanclub-routes.spec.ts tests/e2e/homepage-sections.spec.ts tests/e2e/mobile-navigation.spec.ts",
    "launch-readiness": "node scripts/launch-readiness/run.mjs",
    "deploy:prod": "npm run build:cf && wrangler pages deploy out"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^6.1.3",
    "next": "^15.5.8",
    "next-elfsight-widget": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "24.0.4",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "9.27.0",
    "eslint-config-next": "15.3.3",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "typescript": "5.8.3",
    "vitest": "^3.0.5",
    "wrangler": "^4.35.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
